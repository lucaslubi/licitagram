# ------- Supabase (mesmo projeto do Licitagram, schema licitagov.*) -------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ------- IA — Chain de providers com fallback automático -------
# Ordem: Gemini → OpenRouter-Gemini → DeepSeek → Cerebras → Groq → OpenRouter-Llama
# Pelo menos UM é necessário. Gemini 2.5 Flash é o default (65K output, 1M ctx).
#
# Obtenha em:
#   https://aistudio.google.com/apikey  (Gemini — recomendado, free + 65K out)
#   https://openrouter.ai/keys           (OpenRouter — fallback Gemini + Llama)
#   https://platform.deepseek.com/       (DeepSeek — $0.14/MTok, PT forte)
#   https://console.cerebras.ai/         (Cerebras — free + velocidade)
#   https://console.groq.com/keys        (Groq — free + velocidade)
GEMINI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
CEREBRAS_API_KEY=
GROQ_API_KEY=

# ------- Embeddings (TEI self-host no VPS, 1024 dims multilingual-e5-large) -------
EMBEDDINGS_URL=http://85.31.60.53:8081
EMBEDDINGS_API_KEY=

# ------- Anthropic (opcional, só se quiser voltar a Claude em algum endpoint) -------
ANTHROPIC_API_KEY=

# ------- Redis (compartilhado com packages/workers, prefixo licitagov:) -------
REDIS_URL=

# ------- Stripe (conta compartilhada com Licitagram, produtos separados) -------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ------- Email / notifications -------
RESEND_API_KEY=

# ------- Observability -------
SENTRY_DSN=
SENTRY_RELEASE=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ------- App -------
NEXT_PUBLIC_APP_URL=http://localhost:3001
LOG_LEVEL=debug
