# ------- Supabase (mesmo projeto do Licitagram, schema licitagov.*) -------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ------- IA — Gemini é o provider padrão (AI_MODELS.reasoning + .fast) -------
# Obtenha em https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ------- Anthropic (opcional, só se quiser voltar a Claude em algum endpoint) -------
ANTHROPIC_API_KEY=

# ------- Redis (compartilhado com packages/workers, prefixo licitagov:) -------
REDIS_URL=

# ------- Stripe (conta compartilhada com Licitagram, produtos separados) -------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ------- Email / notifications -------
RESEND_API_KEY=

# ------- Observability -------
SENTRY_DSN=
SENTRY_RELEASE=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ------- App -------
NEXT_PUBLIC_APP_URL=http://localhost:3001
LOG_LEVEL=debug
